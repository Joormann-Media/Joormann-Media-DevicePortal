#!/usr/bin/env python3
import json
import os
import shutil
import subprocess
import sys

CONFIG_PATH = "/etc/device/config.json"
NMCLI = shutil.which("nmcli") or "/usr/bin/nmcli"
HOSTNAME_BIN = shutil.which("hostname") or "/bin/hostname"


def log(msg):
    print(f"[device-wifi-autoconnect] {msg}")


def run(cmd, timeout=20):
    try:
        p = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return p.returncode, (p.stdout or "").strip(), (p.stderr or "").strip()
    except Exception as exc:
        return 127, "", str(exc)


def is_secret_error(out, err):
    blob = (out or "") + "\n" + (err or "")
    blob = blob.lower()
    return (
        "secrets were required" in blob or
        "password" in blob and "not given" in blob or
        "psk" in blob and "not given" in blob or
        "passwd-file" in blob
    )


def is_key_mgmt_missing(out, err):
    blob = (out or "") + "\n" + (err or "")
    blob = blob.lower()
    return "key-mgmt" in blob and "property is missing" in blob


def is_auth_error(out, err):
    blob = (out or "") + "\n" + (err or "")
    blob = blob.lower()
    return (
        "not authorized" in blob or
        "permission denied" in blob or
        "sudo:" in blob and "password" in blob
    )


def read_config():
    try:
        with open(CONFIG_PATH, "r", encoding="utf-8") as f:
            data = json.load(f)
            return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def normalize_profiles(cfg):
    profs = cfg.get("wifi_profiles")
    if not isinstance(profs, list):
        return []
    clean = []
    for p in profs:
        if not isinstance(p, dict):
            continue
        ssid = (p.get("ssid") or "").strip()
        if not ssid:
            continue
        try:
            prio = int(p.get("priority", 0))
        except Exception:
            prio = 0
        auto = bool(p.get("autoconnect", True))
        clean.append({"ssid": ssid, "priority": prio, "autoconnect": auto})
    # dedupe (last wins)
    by_ssid = {}
    for p in clean:
        by_ssid[p["ssid"]] = p
    return list(by_ssid.values())


def get_ip():
    rc, out, _ = run([HOSTNAME_BIN, "-I"], timeout=3)
    if rc == 0 and out:
        return out.split()[0]
    return ""


def main():
    if not os.path.exists(NMCLI):
        log(f"nmcli not found: {NMCLI}")
        return 0

    cfg = read_config()
    preferred = (cfg.get("preferred_wifi") or "").strip()
    profs = normalize_profiles(cfg)

    # Ensure preferred is first
    if preferred:
        found = False
        for p in profs:
            if p["ssid"] == preferred:
                p["priority"] = max(int(p.get("priority", 0)), 999)
                p["autoconnect"] = True
                found = True
                break
        if not found:
            profs.append({"ssid": preferred, "priority": 999, "autoconnect": True})

    profs.sort(key=lambda x: int(x.get("priority") or 0), reverse=True)

    if not profs:
        log("no wifi profiles configured")
        return 0

    for p in profs:
        ssid = p.get("ssid") or ""
        if not ssid:
            continue
        if not p.get("autoconnect", True):
            log(f"skip (autoconnect=false): {ssid}")
            continue

        log(f"trying: {ssid}")
        rc, out, err = run([NMCLI, "connection", "up", ssid], timeout=25)
        if rc == 0:
            ip = get_ip()
            log(f"connected: {ssid}" + (f" ip={ip}" if ip else ""))
            return 0

        if is_secret_error(out, err):
            log(f"secret required, skipping: {ssid}")
            continue
        if is_key_mgmt_missing(out, err):
            log(f"key-mgmt missing, skipping: {ssid}")
            continue
        if is_auth_error(out, err):
            log(f"auth error, skipping: {ssid}")
            continue
        log(f"failed: {ssid} rc={rc}")

    log("no wifi connection established")
    return 0


if __name__ == "__main__":
    sys.exit(main())
